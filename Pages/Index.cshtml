@page
@model dynamic
@{
    ViewData["Title"] = "SecureLab - Insecure Starter";
}
<div class="container py-4">
  <h1>SecureLab — Insecure Starter App</h1>
  <p class="lead">
    This demo app is intentionally insecure. Use the <a href="/Demo">Demo</a> page 
    to exercise endpoints, then fix them as your assignment.
  </p>

  <div class="mt-4">
    <h4>Quick link</h4>
    <ul>
      <li><a href="/Demo">Interactive Demo (Register / Login / Upload / Notes)</a></li>
    </ul>
  </div>

  <div class="alert alert-warning mt-4">
    <strong>Safety:</strong> This app stores passwords and notes in plaintext and exposes uploads. 
    Do not deploy this code to production.
  </div>
</div>
