@page
@model dynamic
@{
    ViewData["Title"] = "Demo - SecureLab";
}
<div class="container py-4">
  <h2>Interactive Demo</h2>

  <section class="mt-3">
    <h5>Register</h5>
    <form method="post" action="/Account/Register">
      <div class="mb-2"><input name="username" class="form-control" placeholder="username"></div>
      <div class="mb-2"><input name="password" type="password" class="form-control" placeholder="password"></div>
      <button class="btn btn-primary">Register</button>
    </form>
  </section>

  <section class="mt-4">
    <h5>Login</h5>
    <form method="post" action="/Account/Login">
      <div class="mb-2"><input name="username" class="form-control" placeholder="username"></div>
      <div class="mb-2"><input name="password" type="password" class="form-control" placeholder="password"></div>
      <button class="btn btn-primary">Login</button>
    </form>
  </section>

  <section class="mt-4">
    <h5>Add Note</h5>
    <form method="post" action="/Profile/Notes">
      <div class="mb-2"><input name="userId" class="form-control" placeholder="userId (e.g., 1)"></div>
      <div class="mb-2"><textarea name="content" class="form-control" rows="3" placeholder="note content"></textarea></div>
      <button class="btn btn-primary">Add Note</button>
    </form>
  </section>

  <section class="mt-4">
    <h5>Upload File</h5>
    <form method="post" enctype="multipart/form-data" action="/Files/Upload">
      <div class="mb-2"><input name="file" type="file" class="form-control"></div>
      <button class="btn btn-primary">Upload</button>
    </form>
  </section>
</div>
