## Ignore Visual Studio temporary files, build results, and common artifacts

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific VS Code settings
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Mono Auto Generated Files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
[Rr]eleases candidate*/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[bB]uild/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/

# Visual Studio 2022 generated config
*.globalconfig.vsbackup

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# xUnit
xunit-*.*.xml

# BenchmarkDotNet Artifacts
BenchmarkDotNet.Artifacts/

# Generated files
Generated*/

# SQL Server files
*.mdf
*.ldf
*.ndf

# Business Intelligence projects
*.rdl.data
*.bim.layout
*.bim_*.settings
*.rptproj.rsuser
*- Backup*.rdl

# Azure local emulator
ecf/
rcf/

# Publish outputs
publish/
[Pp]ublished*/

# NuGet
*.nupkg
*.snupkg
# The packages folder can be ignored because of PackageReference
**/[Pp]ackages/*
!**/[Pp]ackages/build/
# Except build/, which is used as an MSBuild target.
**/[Pp]ackages/build/*/

# Azure Functions localsettings
local.settings.json

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# StyleCop
StyleCopReport.xml

# Files built by Visual Studio
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*.log
*.vspscc
*_i.asm
*_p.asm
*.cache
*.scc

# Others
*.dbmdl
*.bak
*.backup
*.BLOB
*.svclog
*.pidb
*.scc
*.log
*.trace

# OS generated files
.DS_Store
Thumbs.db
ehthumbs.db
Icon?

# Rider / JetBrains
.idea/
*.sln.iml

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# DotCover
*.dotCover

# Coverage
*.coverage
*.coveragexml
coverage*

# TFS
$tf/

# Node (if any frontend assets)
node_modules/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.*

# Backup & report files
*.bak
*.orig
*.svclog

# Local SQLite / other dev DBs
*.sqlite
*.db
*.db-shm
*.db-wal

# Crash dumps
*.dmp

# Security
secrets.json

# Tooling
/.editorconfig.user

# Packages lock (optional, comment if you want to commit)
# packages.lock.json

# Visual Studio Code workspace
*.code-workspace
